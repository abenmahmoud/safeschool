# SafeSchool - variables attendues (ne jamais commiter les vraies valeurs)
# Utiliser les memes noms dans Netlify (Site settings > Environment variables)

# ---- Frontend / Supabase ----
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ---- Backend privileged keys (Functions) ----
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASS=strong_superadmin_password
SUPERADMIN_SESSION_SECRET=replace_with_long_random_secret
SUPERADMIN_SESSION_TTL_SECONDS=28800
PASSWORD_PEPPER=replace_with_random_pepper

# ---- Email transactionnel ----
EMAIL_FROM="SafeSchool <no-reply@safeschool.fr>"
RESEND_API_KEY=re_xxx

# ---- Stripe / Billing ----
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---- Domaine / app ----
SITE_URL=https://app.safeschool.fr
URL=https://app.safeschool.fr
VITE_BASE_DOMAIN=safeschool.fr
