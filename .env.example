# SafeSchool V7 Pro PWA — Variables d'environnement
# Copier vers .env.local et remplir les valeurs
# Ne jamais commiter .env.local

# ═══════════ SUPERADMIN ═══════════
# Identifiants du super-administrateur (fondateur)
SUPERADMIN_EMAIL=your_admin@email.com
SUPERADMIN_PASS=your_secure_password

# ═══════════ SUPABASE ═══════════
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ═══════════ DOMAINE ═══════════
# Domaine de base pour les sous-domaines
VITE_BASE_DOMAIN=safeschool.fr

# ═══════════ STRIPE (Facturation) ═══════════
# Obtenez vos cles sur https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLIC_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ═══════════ EMAIL (Notifications) ═══════════
# Provider: SendGrid ou Resend
# SENDGRID_API_KEY=SG...
# RESEND_API_KEY=re_...
# EMAIL_FROM=notifications@safeschool.fr

# ═══════════ PUSH NOTIFICATIONS (V7 Pro) ═══════════
# Generez avec: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=BJ...
# VAPID_PRIVATE_KEY=...
